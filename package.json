{
  "name": "timeoff-service",
  "version": "1.0.0",
  "description": "Production-grade Time-Off microservice built with NestJS, TypeScript, TypeORM, and SQLite.",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "build": "nest build",
    "start": "node dist/src/main.js",
    "start:dev": "nest start --watch",
    "mock:hcm": "ts-node -r tsconfig-paths/register mock-hcm/server.ts",
    "test": "jest --runInBand",
    "test:cov": "jest --runInBand --coverage",
    "test:unit": "jest --runInBand test/unit",
    "test:integration": "jest --runInBand test/integration",
    "test:e2e": "jest --runInBand test/e2e"
  },
  "dependencies": {
    "@nestjs/common": "11.1.19",
    "@nestjs/core": "11.1.19",
    "@nestjs/platform-express": "11.1.19",
    "@nestjs/typeorm": "11.0.1",
    "axios": "1.15.2",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "sqlite3": "5.1.7",
    "typeorm": "0.3.28"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.21",
    "@nestjs/testing": "11.1.19",
    "@types/jest": "29.5.14",
    "@types/node": "24.10.1",
    "@types/supertest": "7.2.0",
    "jest": "29.7.0",
    "supertest": "7.2.2",
    "ts-jest": "29.4.9",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.9.3"
  }
}
